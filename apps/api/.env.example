PORT=3001

# PostgreSQL (see infra/docker/docker-compose.yml). DATABASE_URL is the
# migration-running role (superuser-equivalent — must be able to CREATE/ALTER
# tables). APP_DATABASE_URL is what the running app actually connects as: a
# least-privilege role with no CREATE/ALTER/DROP, created by the
# app_role_least_privilege migration (see ADR-0015). Postgres RLS (see the
# row_level_security migration) is a silent no-op without it, since
# superusers always bypass RLS — PrismaService logs a warning at startup if
# APP_DATABASE_URL is unset and falls back to DATABASE_URL.
DATABASE_URL=postgresql://dip:dip@localhost:5432/dip
APP_DATABASE_URL=postgresql://dip_app:dip-app-dev-only-change-me@localhost:5432/dip

# Auth (see ADR-0005). Generate real secrets for any non-local environment, e.g.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_TTL_SECONDS=900

# Per-tenant integration credentials encryption key (see ADR-0012). Generate a real
# secret for any non-local environment, e.g.: openssl rand -base64 48
INTEGRATION_CREDENTIALS_ENCRYPTION_KEY=dev-only-change-me

# AI drafting for Decision Intelligence Engine analyses (see ADR-0018).
# Entirely optional — leave unset and every existing feature works exactly
# as before; GET /decision-intelligence/ai-status reports { available: false }
# and POST /incidents/:id/analyze/draft returns 503, never a crash. Set a
# spend limit on the key itself in the Anthropic Console — that's the real
# lever for cost control, not anything in this codebase.
ANTHROPIC_API_KEY=
# Defaults to Haiku 4.5 (cheapest current model) if unset — a draft only
# needs to be a good starting point for human review, not a final product.
# Override to e.g. claude-sonnet-5 for higher-quality drafts at higher cost.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
