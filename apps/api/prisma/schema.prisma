generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

/// A customer organization. All tenant-owned data is scoped by tenantId
/// (see ADR-0004 — shared schema, application-layer tenant scoping).
model Tenant {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   Membership[]

  incidents              Incident[]
  decisions              Decision[]
  evidence               Evidence[]
  timelineEvents         TimelineEvent[]
  actions                Action[]
  intelligenceAnalyses   IntelligenceAnalysis[]
  executiveBriefs        ExecutiveBrief[]
  decisionReports        DecisionReport[]
  lessonsLearned         LessonLearned[]
  integrationConfigs     IntegrationConfig[]
  decisionOutcomes       DecisionOutcome[]
  entities               Entity[]
  relationships          Relationship[]
  entityMergeSuggestions EntityMergeSuggestion[]
  auditLogEntries        AuditLogEntry[]

  @@map("tenants")
}

/// A person who can authenticate. A User may belong to multiple tenants
/// via Membership (e.g. a consultant working with several customers).
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  memberships   Membership[]
  refreshTokens RefreshToken[]

  createdIncidents         Incident[]              @relation("IncidentCreatedBy")
  createdDecisions         Decision[]              @relation("DecisionCreatedBy")
  decidedDecisions         Decision[]              @relation("DecisionDecidedBy")
  submittedEvidence        Evidence[]              @relation("EvidenceSubmittedBy")
  timelineActions          TimelineEvent[]         @relation("TimelineEventActor")
  assignedActions          Action[]                @relation("ActionAssignedTo")
  submittedAnalyses        IntelligenceAnalysis[]  @relation("IntelligenceAnalysisSubmittedBy")
  generatedBriefs          ExecutiveBrief[]        @relation("ExecutiveBriefGeneratedBy")
  generatedReports         DecisionReport[]        @relation("DecisionReportGeneratedBy")
  createdLessons           LessonLearned[]         @relation("LessonLearnedCreatedBy")
  recordedOutcomes         DecisionOutcome[]       @relation("DecisionOutcomeRecordedBy")
  confirmedRelationships   Relationship[]          @relation("RelationshipConfirmedBy")
  reviewedMergeSuggestions EntityMergeSuggestion[] @relation("MergeSuggestionReviewedBy")
  auditLogEntries          AuditLogEntry[]         @relation("AuditLogActor")

  @@map("users")
}

/// The join between User and Tenant, carrying the RBAC role for that tenant.
/// A given user has exactly one role per tenant.
model Membership {
  id       String @id @default(uuid())
  role     Role   @default(MEMBER)
  userId   String
  tenantId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("memberships")
}

/// Server-side record of issued refresh tokens so they can be individually
/// revoked (see ADR-0005 — revocable refresh tokens over pure stateless JWT).
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Phase 3 — Incident / Decision domain model (see ADR-0006, ADR-0007)
// ---------------------------------------------------------------------------

enum IncidentStatus {
  OPEN
  MITIGATED
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Drives the evidenceCompleteness lookup table (see ADR-0010). OTHER
/// requires no specific evidence sources — an unclassified incident is
/// never penalized for a checklist that doesn't apply to it.
enum IncidentType {
  CLOUD_OUTAGE
  SECURITY_BREACH
  DATA_LOSS
  PERFORMANCE_DEGRADATION
  OTHER
}

enum DecisionStatus {
  OPEN
  DECIDED
  CANCELLED
}

enum EvidenceType {
  LOG
  METRIC
  HUMAN_INPUT
  EXTERNAL_LINK
  OTHER
}

/// Which category of system this evidence came from — distinct from
/// EvidenceType (what kind of artifact it is). Drives evidenceCompleteness
/// and sourceReliability (see ADR-0010).
enum EvidenceSourceCategory {
  MONITORING
  CLOUD_PROVIDER
  LOG_AGGREGATOR
  TICKETING
  CHAT
  HUMAN
  OTHER
}

enum TimelineEventType {
  INCIDENT_CREATED
  INCIDENT_STATUS_CHANGED
  DECISION_OPENED
  DECISION_DECIDED
  DECISION_CANCELLED
  EVIDENCE_ADDED
  ACTION_CREATED
  ACTION_STATUS_CHANGED
  INTELLIGENCE_ANALYSIS_GENERATED
  EXECUTIVE_BRIEF_GENERATED
  DECISION_REPORT_GENERATED
  LESSON_LEARNED_CREATED
  INTEGRATION_BLOCKED
  DECISION_OUTCOME_RECORDED
}

enum ActionStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

/// An incident being tracked and worked through the platform. Strictly
/// tenant-scoped (see ADR-0004 / ADR-0006) via `tenantId`.
model Incident {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      IncidentStatus   @default(OPEN)
  severity    IncidentSeverity @default(MEDIUM)
  type        IncidentType     @default(OTHER)

  createdByUserId String
  createdBy       User      @relation("IncidentCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?

  decisions            Decision[]
  evidence             Evidence[]
  timelineEvents       TimelineEvent[]
  actions              Action[]
  intelligenceAnalyses IntelligenceAnalysis[]
  executiveBriefs      ExecutiveBrief[]
  lessonsLearned       LessonLearned[]

  @@index([tenantId])
  @@map("incidents")
}

/// A decision to be made (or made) in response to an incident. `status`
/// can only become DECIDED through DecisionsService.decide(), which
/// enforces Principle 1 — see ADR-0007: a real, tenant-member human must
/// be named in `decidedByUserId` alongside a non-empty `humanDecision`.
model Decision {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  question String
  status   DecisionStatus @default(OPEN)

  /// The human-authored decision text. Null until `status = DECIDED`.
  humanDecision String?
  rationale     String?

  /// The named human stakeholder who made the decision (Principle 1 — never
  /// null when status = DECIDED, enforced in DecisionsService, not the DB).
  decidedByUserId String?
  decidedBy       User?     @relation("DecisionDecidedBy", fields: [decidedByUserId], references: [id])
  decidedAt       DateTime?

  createdByUserId String
  createdBy       User     @relation("DecisionCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evidence        Evidence[]
  timelineEvents  TimelineEvent[]
  actions         Action[]
  decisionReports DecisionReport[]
  outcome         DecisionOutcome?

  @@index([tenantId])
  @@index([incidentId])
  @@map("decisions")
}

/// A piece of evidence backing an incident and/or a specific decision.
/// `submittedByUserId` is nullable because evidence may originate from an
/// automated integration (see ADR-0008), not only a human submitter.
model Evidence {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  decisionId String?
  decision   Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  type           EvidenceType
  sourceCategory EvidenceSourceCategory @default(OTHER)
  source         String
  summary        String
  url            String?

  submittedByUserId String?
  submittedBy       User?    @relation("EvidenceSubmittedBy", fields: [submittedByUserId], references: [id])
  createdAt         DateTime @default(now())

  entityEvidenceLinks       EntityEvidenceLink[]
  relationshipEvidenceLinks RelationshipEvidenceLink[]

  @@index([tenantId])
  @@index([incidentId])
  @@map("evidence")
}

/// Append-only audit trail for an incident (and optionally a specific
/// decision). Not directly writable via the API — every service that
/// mutates Incident/Decision/Evidence/Action state writes its own row
/// here in the same operation (see ADR-0006).
model TimelineEvent {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  decisionId String?
  decision   Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  type        TimelineEventType
  description String

  /// Null for system-generated events with no human actor.
  actorUserId String?
  actor       User?    @relation("TimelineEventActor", fields: [actorUserId], references: [id])
  metadata    Json?
  occurredAt  DateTime @default(now())

  @@index([tenantId])
  @@index([incidentId])
  @@map("timeline_events")
}

/// A follow-up task arising from an incident and/or a specific decision.
model Action {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  decisionId String?
  decision   Decision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  title  String
  status ActionStatus @default(PENDING)

  assignedToUserId String?
  assignedTo       User?     @relation("ActionAssignedTo", fields: [assignedToUserId], references: [id])
  dueAt            DateTime?
  completedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([incidentId])
  @@map("actions")
}

// ---------------------------------------------------------------------------
// Phase 4 — Decision Intelligence Engine (see ADR-0010)
// ---------------------------------------------------------------------------

/// A persisted AI Output Contract (see ADR-0010): the four confidence
/// dimensions are stored as separate columns — never merged into one score,
/// including at the persistence layer — computed server-side from Evidence
/// rows and never accepted from a client. The qualitative fields are
/// supplied by whoever calls POST /incidents/:id/analyze (today: a human
/// analyst; later: a real LLM integration), validated against the same
/// AIOutputContractDto either way.
model IntelligenceAnalysis {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  // --- Confidence dimensions (ADR-0010) — four independent 0-100 scores ---
  evidenceCompleteness Int
  sourceReliability    Int
  dataFreshness        Int
  aiCertainty          Int

  // --- Computed, never client-supplied ---
  evidenceUsed       String[]
  missingInformation String[]

  // --- Supplied by the caller (human analyst or future LLM integration) ---
  situationSummary       String
  businessImpact         Json
  criticalRisks          Json
  conflictingInformation String[]
  recommendedDecision    Json
  alternativeDecisions   Json
  expectedConsequences   String
  immediateNextActions   String[]
  executiveSummary       String

  submittedByUserId String
  submittedBy       User     @relation("IntelligenceAnalysisSubmittedBy", fields: [submittedByUserId], references: [id])
  createdAt         DateTime @default(now())

  decisionOutcomes DecisionOutcome[]

  @@index([tenantId])
  @@index([incidentId])
  @@map("intelligence_analyses")
}

// ---------------------------------------------------------------------------
// Phase 5 — Reporting (see ADR-0011)
// ---------------------------------------------------------------------------

/// An immutable, point-in-time generated summary of an incident (see
/// ADR-0011). Every field except `additionalNotes` is a factual snapshot
/// computed server-side at generation time — never fabricated narrative.
/// Generating a new brief creates a new row; history is preserved.
model ExecutiveBrief {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  title            String
  incidentStatus   IncidentStatus
  incidentSeverity IncidentSeverity
  summary          String
  businessImpact   Json?
  keyDecisions     Json
  openRisks        Json
  nextActions      Json
  additionalNotes  String?

  generatedByUserId String
  generatedBy       User     @relation("ExecutiveBriefGeneratedBy", fields: [generatedByUserId], references: [id])
  generatedAt       DateTime @default(now())

  @@index([tenantId])
  @@index([incidentId])
  @@map("executive_briefs")
}

/// An immutable, point-in-time snapshot of a single decision — question,
/// outcome, evidence used, and relevant timeline (see ADR-0011).
model DecisionReport {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  decisionId String
  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  incidentId String

  question        String
  status          DecisionStatus
  humanDecision   String?
  rationale       String?
  decidedByUserId String?
  decidedAt       DateTime?
  evidenceSummary Json
  timelineSummary Json
  additionalNotes String?

  generatedByUserId String
  generatedBy       User     @relation("DecisionReportGeneratedBy", fields: [generatedByUserId], references: [id])
  generatedAt       DateTime @default(now())

  @@index([tenantId])
  @@index([decisionId])
  @@map("decision_reports")
}

/// A human-authored retrospective knowledge artifact (see ADR-0011). Not
/// computable from structured data — genuine insight requires a person.
/// Only creatable for a CLOSED incident (enforced in LessonsLearnedService).
/// The Knowledge Base (Phase 5) is search over these rows.
model LessonLearned {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  title         String
  whatHappened  String
  whatWentWell  String[]
  whatToImprove String[]
  actionItems   String[]
  tags          String[]

  createdByUserId String
  createdBy       User     @relation("LessonLearnedCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([incidentId])
  @@map("lessons_learned")
}

// ---------------------------------------------------------------------------
// Decision outcome calibration (see ADR-0016) — closes the loop between the
// Decision Intelligence Engine's confidence dimensions (ADR-0010) and what
// actually happened. The outcome judgment is always human-attested, never
// computed by the system itself — same Principle 1 discipline as
// DecisionsService.decide().
// ---------------------------------------------------------------------------

enum DecisionOutcomeQuality {
  GOOD
  BAD
  MIXED
  UNKNOWN
}

/// A human's retrospective judgment of whether a DECIDED decision turned out
/// well — only recordable once the incident is CLOSED (mirrors
/// LessonLearned's gate: a retrospective before closure isn't one). Links to
/// whichever IntelligenceAnalysis existed at decision time (if any), so
/// CalibrationService can correlate its confidence dimensions with a real,
/// human-attested outcome. One outcome per decision.
model DecisionOutcome {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  decisionId String   @unique
  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  intelligenceAnalysisId String?
  intelligenceAnalysis   IntelligenceAnalysis? @relation(fields: [intelligenceAnalysisId], references: [id], onDelete: SetNull)

  outcomeQuality DecisionOutcomeQuality
  notes          String?

  recordedByUserId String
  recordedBy       User     @relation("DecisionOutcomeRecordedBy", fields: [recordedByUserId], references: [id])
  recordedAt       DateTime @default(now())

  @@index([tenantId])
  @@map("decision_outcomes")
}

// ---------------------------------------------------------------------------
// Phase 6 — Integration resilience + per-tenant configuration (see ADR-0012)
// ---------------------------------------------------------------------------

/// The ten Phase 6 enterprise systems (see ADR-0008 / ADR-0012). Moved into
/// the Prisma schema (from a hand-written TS enum) so @prisma/client is the
/// single source of truth — apps/api/src/integrations imports it rather
/// than redeclaring it.
enum IntegrationKey {
  SERVICENOW
  JIRA
  SLACK
  TEAMS
  AWS
  AZURE
  GCP
  SPLUNK
  DATADOG
  MICROSOFT_SENTINEL
}

enum IntegrationConfigStatus {
  ACTIVE
  BROKEN
}

/// A tenant's configuration for one integration. Credentials are never
/// stored in plaintext or in environment variables (see ADR-0012) — always
/// AES-256-GCM encrypted via CredentialsEncryptionService. Absent or
/// `BROKEN` config means the provider runs in STUB_MODE (see
/// ConfigurableIntegrationProvider).
model IntegrationConfig {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  providerType         IntegrationKey
  encryptedCredentials String
  status               IntegrationConfigStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, providerType])
  @@index([tenantId])
  @@map("integration_configs")
}

// ---------------------------------------------------------------------------
// Entity-relationship intelligence graph + analyst-activity audit log
// (see ADR-0021). Every entity and relationship must trace back to real
// Evidence — "never a bare assertion", the same rule the confidence
// breakdowns (ADR-0019) already follow. Every relationship a human hasn't
// explicitly confirmed stays SUGGESTED — Principle 1 (ADR-0007) extended
// from decisions to connections between people, orgs, locations, events.
// ---------------------------------------------------------------------------

enum EntityType {
  PERSON
  ORGANIZATION
  LOCATION
  EVENT
  OTHER
}

/// A person, organization, location, or event an analyst is tracking.
/// Accumulates across incidents over time — not scoped to a single one.
model Entity {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type       EntityType
  name       String
  /// Known alternate names/spellings — raw material for merge suggestions
  /// below, never auto-applied.
  aliases    String[]
  /// Type-specific fields (DOB, registration number, coordinates...).
  /// Deliberately flexible rather than a rigid per-type schema this early.
  attributes Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidenceLinks       EntityEvidenceLink[]
  relationshipsFrom   Relationship[]          @relation("RelationshipFrom")
  relationshipsTo     Relationship[]          @relation("RelationshipTo")
  mergeSuggestionsAsA EntityMergeSuggestion[] @relation("MergeSuggestionEntityA")
  mergeSuggestionsAsB EntityMergeSuggestion[] @relation("MergeSuggestionEntityB")

  @@index([tenantId, type])
  @@map("entities")
}

enum RelationshipType {
  ASSOCIATED_WITH
  EMPLOYED_BY
  MEMBER_OF
  LOCATED_AT
  PRESENT_AT
  COMMUNICATED_WITH
  TRANSACTED_WITH
  OWNS
  OTHER
}

enum RelationshipStatus {
  /// System/pattern-detected — never treated as fact until a human reviews it.
  SUGGESTED
  /// A named human confirmed it (see confirmedByUserId).
  CONFIRMED
  /// A human reviewed and said no — kept, not deleted (Principle 3: never
  /// hidden by omission; a rejected hypothesis is still part of the record).
  REJECTED
}

/// A directed edge between two entities. Can only reach CONFIRMED once it
/// has at least one RelationshipEvidenceLink — enforced in
/// RelationshipsService, not just documented here.
model Relationship {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fromEntityId String
  fromEntity   Entity @relation("RelationshipFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntityId   String
  toEntity     Entity @relation("RelationshipTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  type   RelationshipType
  /// Free-text specifics when `type` alone doesn't capture the relationship.
  label  String?
  status RelationshipStatus @default(SUGGESTED)

  confirmedByUserId String?
  confirmedBy       User?     @relation("RelationshipConfirmedBy", fields: [confirmedByUserId], references: [id])
  confirmedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evidenceLinks RelationshipEvidenceLink[]

  @@index([tenantId, fromEntityId])
  @@index([tenantId, toEntityId])
  @@map("relationships")
}

/// The "why" behind an entity's existence — the specific evidence that
/// named it. An entity with no evidence link should never exist in
/// practice; enforced in EntitiesService, not just by this schema.
model EntityEvidenceLink {
  id       String @id @default(uuid())
  tenantId String

  entityId      String
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  evidenceId    String
  evidence      Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  /// The specific snippet that named this entity, if known.
  extractedText String?

  createdAt DateTime @default(now())

  @@unique([entityId, evidenceId])
  @@index([tenantId])
  @@map("entity_evidence_links")
}

/// The "why" behind a relationship — the specific evidence that supports it.
model RelationshipEvidenceLink {
  id       String @id @default(uuid())
  tenantId String

  relationshipId String
  relationship   Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  evidenceId     String
  evidence       Evidence     @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([relationshipId, evidenceId])
  @@index([tenantId])
  @@map("relationship_evidence_links")
}

enum MergeSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

/// "Is J. Smith the same person as John Smith?" — the system suggests,
/// it never auto-merges. Kept even when rejected, same reasoning as
/// RelationshipStatus.REJECTED above.
model EntityMergeSuggestion {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  entityAId String
  entityA   Entity @relation("MergeSuggestionEntityA", fields: [entityAId], references: [id], onDelete: Cascade)
  entityBId String
  entityB   Entity @relation("MergeSuggestionEntityB", fields: [entityBId], references: [id], onDelete: Cascade)

  /// Why the system thinks these might be the same entity — always shown,
  /// never a bare "possible match".
  reason String
  status MergeSuggestionStatus @default(PENDING)

  reviewedByUserId String?
  reviewedBy       User?     @relation("MergeSuggestionReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("entity_merge_suggestions")
}

enum AuditAction {
  SEARCH
  VIEW_ENTITY
  VIEW_RELATIONSHIP
  VIEW_GRAPH
  CREATE_ENTITY
  CREATE_RELATIONSHIP
  CONFIRM_RELATIONSHIP
  REJECT_RELATIONSHIP
  MERGE_ENTITIES
  EXPORT
}

/// Append-only record of analyst activity against the intelligence graph —
/// the concrete mechanism behind "protect civil liberties, human control,
/// not automated surveillance" (see ADR-0021). This logs what the ANALYST
/// did, not just what the system found: who looked up whom, when, and
/// (for read actions on sensitive data) why. Never updated or deleted —
/// no such endpoint exists, matching TimelineEvent's existing immutability.
model AuditLogEntry {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  actorUserId String
  actor       User        @relation("AuditLogActor", fields: [actorUserId], references: [id])
  action      AuditAction

  /// Free-text tag for the kind of record touched (e.g. "Entity",
  /// "Relationship") — deliberately not a foreign key, since the target
  /// may reference any of several tables (or none, for a SEARCH).
  targetType String?
  targetId   String?

  /// Analyst-stated purpose — required for SEARCH/VIEW_* actions at the
  /// service layer (purpose limitation), optional for actions that are
  /// already self-documenting (e.g. CONFIRM_RELATIONSHIP already requires
  /// an evidence citation).
  reason   String?
  /// Action-specific detail — search terms, graph traversal depth, export
  /// format. Never used to store the underlying sensitive data itself.
  metadata Json?

  occurredAt DateTime @default(now())

  @@index([tenantId, actorUserId, occurredAt])
  @@index([tenantId, targetType, targetId])
  @@map("audit_log_entries")
}
